# Required: Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# Optional: Cross-origin allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Optional: Email sending via SendGrid
# SENDGRID_API_KEY=SG.xxx
# CONTACT_EMAIL_TO=you@example.com
# CONTACT_EMAIL_FROM=noreply@example.com

# Optional: Server port (default: 3001)
# PORT=3001
